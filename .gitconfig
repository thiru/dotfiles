[alias]
  a = add -A
  a3 = !sh -c 'git add -A && git commit --amend --reset-author'
  ap = add -p
  br = branch
  bra = branch -a
  brd = "!f() { git branch -d $1; git push origin :$1; }; f"
  brD = "!f() { git branch -D $1; git push origin :$1; }; f"
  c = "!f() { git commit -m \"$*\"; }; f"
  ca = commit --amend --reset-author
  ci = commit
  co = checkout
  cp = cherry-pick
  cbuild = "!f() { git commit -m \"build: $*\"; }; f"
  cchore = "!f() { git commit -m \"chore: $*\"; }; f"
  cci = "!f() { git commit -m \"ci: $*\"; }; f"
  cdocs = "!f() { git commit -m \"docs: $*\"; }; f"
  cfeat = "!f() { git commit -m \"feat: $*\"; }; f"
  cfix = "!f() { git commit -m \"fix: $*\"; }; f"
  cperf = "!f() { git commit -m \"perf: $*\"; }; f"
  crefactor = "!f() { git commit -m \"refactor: $*\"; }; f"
  crevert = "!f() { git commit -m \"revert: $*\"; }; f"
  cstyle = "!f() { git commit -m \"style: $*\"; }; f"
  ctest = "!f() { git commit -m \"test: $*\"; }; f"
  d = diff
  ds = diff --staged
  df = difftool
  dfb = "git-dfb"
  dfs = difftool --staged
  fw = commit -m'feat: wip'
  l = log --pretty=format:'%C(yellow)%h%Creset %s %C(green)[%ar] %C(red)[%an]' -20 --graph
  ll = log --pretty=format:'%C(yellow)%h%Creset %s %C(green)[%ar] %C(red)[%an]' --graph
  p = pull --rebase
  ps = push
  psf = push --force-with-lease
  rba = rebase --abort
  rbc = rebase --continue
  rbi = "!f() { git rebase --interactive HEAD~${1-5}; }; f"
  re = "!git branch --sort=-committerdate | head -n 10 ; git branch --sort=-committerdate -a | grep -E 'origin' | grep -v 'HEAD' | sed 's,remotes/,,' | head -n 10"
  rh = reset --hard
  rs = reset --soft HEAD~
  s = status
[init]
  defaultBranch = master
[credential]
  helper = /usr/lib/git-core/git-credential-libsecret
[core]
  filemode = false
  autocrlf = false
  editor = nvim
  pager = delta
[color]
  ui = auto
[delta]
  navigate = true
[diff]
  colorMoved = default
  tool = nvimdiff
[interactive]
  diffFilter = delta --color-only
[merge]
  tool = nvimdiff
  conflictstyle = diff3
[mergetool]
  keepBackup = false
[push]
  default = simple
